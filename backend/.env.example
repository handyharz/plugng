PORT=8085
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/plugng
FRONTEND_URL=http://localhost:3005

# Existing payment rail
PAYSTACK_SECRET_KEY=sk_test_placeholder

# Redis (Upstash)
# Get from Upstash Console
REDIS_URL=rediss://default:<password>@<region>.upstash.io:6379

# AfriExchange Path A
# Nigeria checkout shows card + wallet.
# Selected XOF countries show AfriExchange when this flag is on.
AFRIEXCHANGE_ENABLED=true
AFRIEXCHANGE_API_BASE_URL=https://afrix-iqvq.onrender.com/api/v1
AFRIEXCHANGE_MERCHANT_API_KEY=replace-with-afriexchange-merchant-api-key
AFRIEXCHANGE_WEBHOOK_SECRET=replace-with-afriexchange-webhook-secret
AFRIEXCHANGE_DEFAULT_TOKEN_TYPE=CT
AFRIEXCHANGE_NGN_TO_XOF_RATE=0.40
AFRIEXCHANGE_RETURN_URL=http://localhost:3005/checkout/success?provider=afriexchange

# Configure the merchant webhook URL in the AfriExchange merchant portal:
# https://plugng.onrender.com/api/v1/webhooks/afriexchange
# Termii (SMS Notifications)
# Get API Key from Termii Dashboard
TERMII_API_KEY=TLxxxxxxxxxxxxxxxxxxxxxxxx
TERMII_SENDER_ID=PlugNG

# Email (Resend)
# Get API Key from Resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=no-reply@plugng.shop

# CORS / Frontend Integration
FRONTEND_URL=http://localhost:3000
# Optional comma-separated extra frontend origins
CORS_ORIGINS=https://plugng.shop,https://www.plugng.shop

# Admin Defaults
ADMIN_EMAIL=admin@plugng.shop
ADMIN_PASSWORD=SetSecurePasswordHere123!
