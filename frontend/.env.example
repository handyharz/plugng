# API URL (Backend)
# Production: https://plugng.onrender.com/api/v1
# Local: http://localhost:8085/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8085/api/v1

# Environment
NODE_ENV=development

# Nigeria checkout shows card + wallet.
# Selected XOF countries show AfriExchange when this flag is on.
# NEXT_PUBLIC_API_URL=https://plugng.onrender.com/api/v1
NEXT_PUBLIC_AFRIEXCHANGE_ENABLED=true
NEXT_PUBLIC_NGN_TO_XOF_RATE=0.37

